#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/e/prog/bartender/node_modules/.pnpm/vega-lite@6.4.2_vega@6.2.0/node_modules/vega-lite/node_modules:/mnt/e/prog/bartender/node_modules/.pnpm/vega-lite@6.4.2_vega@6.2.0/node_modules:/mnt/e/prog/bartender/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/e/prog/bartender/node_modules/.pnpm/vega-lite@6.4.2_vega@6.2.0/node_modules/vega-lite/node_modules:/mnt/e/prog/bartender/node_modules/.pnpm/vega-lite@6.4.2_vega@6.2.0/node_modules:/mnt/e/prog/bartender/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vega-lite/bin/vl2vg" "$@"
else
  exec node  "$basedir/../vega-lite/bin/vl2vg" "$@"
fi
